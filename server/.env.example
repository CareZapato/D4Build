# ============================================================================
# 🔧 EJEMPLO DE CONFIGURACIÓN - D4Builds Backend
# ============================================================================
# 
# Copia este archivo como .env y configura tus valores reales
# NO compartas el archivo .env ni lo subas a git
# 
# ============================================================================

# ----------------------------------------------------------------------------
# SERVIDOR
# ----------------------------------------------------------------------------
PORT=3001

# ----------------------------------------------------------------------------
# BASE DE DATOS POSTGRESQL
# ----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_contraseña_segura
DB_NAME=d4buildsbd

# ----------------------------------------------------------------------------
# JWT (JSON WEB TOKEN)
# ----------------------------------------------------------------------------
# IMPORTANTE: Cambia este secret en producción por uno único y seguro
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_este_secret_en_produccion_usar_64_caracteres_minimo
JWT_EXPIRES_IN=7d

# ----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ----------------------------------------------------------------------------
# En DESARROLLO (NODE_ENV=development):
#   - Se aceptan AUTOMÁTICAMENTE todos los localhost:* (cualquier puerto)
#   - Se aceptan AUTOMÁTICAMENTE IPs de red local (192.168.x.x, 10.x.x.x, 172.16-31.x.x)
#   - No necesitas configurar nada, funcionará con cualquier puerto de Vite
#
# En PRODUCCIÓN (NODE_ENV=production):
#   - Debes especificar la lista exacta de orígenes permitidos
#   - Separar múltiples orígenes con comas
#
# Ejemplos:
#   - Desarrollo: * (acepta todo automáticamente)
#   - Producción: https://tu-dominio.com,https://www.tu-dominio.com
#   - Múltiples: http://localhost:3000,http://192.168.1.100:5173,https://app.ejemplo.com
#
# ⚠️  Usar '*' en producción NO es recomendado por seguridad
CORS_ORIGIN=*

# ----------------------------------------------------------------------------
# ENTORNO
# ----------------------------------------------------------------------------
# Valores: development | production | test
NODE_ENV=development

# ----------------------------------------------------------------------------
# AUTO-MIGRACIÓN DE BASE DE DATOS
# ----------------------------------------------------------------------------
# Si es 'true', verifica y recrea tablas automáticamente al iniciar el servidor
# Útil para desarrollo y despliegues en producción sin estado
AUTO_MIGRATE=true
