# ============================================================================
# VARIABLES DE ENTORNO PARA PRODUCCIÓN
# ============================================================================
# IMPORTANTE: No subas este archivo a Git. Copia estos valores al panel
# de variables de entorno de tu servicio de hosting.

# Base de datos PostgreSQL
DB_HOST=<hostname-generado-por-tu-servicio>.oregon-postgres.render.com
DB_PORT=5432
DB_NAME=d4buildsbd
DB_USER=d4builds_admin
DB_PASSWORD=<contraseña-generada-automáticamente>

# JWT - Genera una clave aleatoria de al menos 32 caracteres
# Puedes usar: openssl rand -base64 32
JWT_SECRET=<REEMPLAZA-CON-CLAVE-ALEATORIA-LARGA>
JWT_EXPIRES_IN=7d

# CORS - Tu dominio de producción (sin barra final)
CORS_ORIGIN=https://tu-dominio-produccion.com
NODE_ENV=production

# Puerto del servidor
PORT=3001

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
# 1. Después de crear la base de datos, ejecuta las migraciones:
#    npm run migrate
#
# 2. Crea el usuario admin inicial (desde el servidor):
#    cd server && node check-admin.js
#
# 3. El frontend debe apuntar a la URL de tu backend en producción
#
# 4. CORS_ORIGIN debe ser la URL exacta de tu frontend (ej: https://d4builds.com)
#    NO incluyas http://localhost en producción
